PORT=5000
NODE_ENV=development
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key
JWT_SECRET=your-supabase-jwt-secret
# Senha do banco (somente para scripts de migração: scripts/apply-delta.js)
SUPABASE_DB_PASSWORD=

# CORS: em produção restrinja ao domínio final (lista separada por vírgula)
CORS_ORIGINS=*
# Rate limit por IP+rota
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Configs atualizáveis sem redeploy
SALARIO_MINIMO=1412.00
SALARIO_MINIMO_VIGENCIA=2024
FIES_TAXA=0.068

# NPS: ciclo vigente (1 resposta por usuário por ciclo)
NPS_CICLO=beta-2026

# Moderação da comunidade: termos extras separados por vírgula (opcional)
MODERATION_BLACKLIST=

# Compliance / dados legais (Roadmap Final - Fase 3)
# Preencha somente com dados juridicos reais antes de publicar.
TERMS_VERSION=2026-07-06
PRIVACY_POLICY_VERSION=2026-07-06
TERMS_URL=/termos-de-uso
PRIVACY_URL=/politica-de-privacidade
SUPPORT_EMAIL=suporte@seudominio.com.br
SUPPORT_WHATSAPP=
DPO_EMAIL=
CNPJ=
RAZAO_SOCIAL=

# Storage de documentos (Roadmap Final - Fase 1, item 1)
DOCUMENTS_BUCKET=documents

# Scan de virus em uploads (Roadmap Final - Fase 1, item 2)
# Sem CLAMAV_HOST definido, o scan cai para deteccao apenas da assinatura EICAR de teste.
# `docker compose up -d clamav` sobe o daemon real (ver docker-compose.yml na raiz); depois defina:
# CLAMAV_HOST=localhost
CLAMAV_HOST=
CLAMAV_PORT=3310

# Integrações externas (Hubs E, G, H)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_VERSION=2023-06-01
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
FIREBASE_SERVER_KEY=
GOOGLE_MAPS_API_KEY=

# Fontes de dados abertos MEC/INEP/FNDE (Hub B)
MEC_PROUNI_API_URL=
INEP_SISU_API_URL=
FNDE_FIES_API_URL=
INEP_ENEM_API_URL=

# Observabilidade (Fase 4)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SLACK_WEBHOOK_URL=
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com
